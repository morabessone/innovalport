# ============================================================================
# Variables para el script de test y las Edge Functions.
# Copiá este archivo a .env y completá los valores. NUNCA commitees el .env.
# ============================================================================

# --- Contabilium (Mi Cuenta → Configuración → API → Credenciales) ---
CONTABILIUM_CLIENT_ID=          # email de la cuenta de Contabilium
CONTABILIUM_CLIENT_SECRET=      # API Key
CONTABILIUM_BASE_URL=https://rest.contabilium.com

# --- Supabase (para deployar functions y correr el worker) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- OCR de facturas (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Endpoints de Contabilium marcados [VERIFICAR] (ajustar tras el sondeo) ---
# CB_EP_PRODUCTOS=/api/productos
# CB_EP_PRODUCTO_STOCK=/api/productos/stock
# CB_EP_AJUSTE_STOCK=/api/stock/ajuste
# CB_EP_NC_RAPIDA=/api/comprobantes/anularrapido
